_repo_root = Path(__file__).resolve().parent.parent
if (_repo_root / 'core' / 'q3n.py').exists():
    sys.path.insert(0, str(_repo_root))

from core import __version__
from core.q3n import (Q3NEntry, parse_file, parse, serialize_file,
                      export_file, export_json, export_markdown,
