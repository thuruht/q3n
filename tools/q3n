def main():
    import argparse
    parser = argparse.ArgumentParser(
        description='Q3N — Quote Triple-Slash Notation CLI',
        formatter_class=argparse.RawTextHelpFormatter)
    parser.add_argument('--version', action='version', version=f'q3n {__version__}')
    parser.add_argument('--no-color', action='store_true',
                        help='Disable colored output')
    sub = parser.add_subparsers(dest='command', title='commands')

    # show
    p = sub.add_parser('show', help='Display entries')
    p.add_argument('file', help='Q3N file')
    p.add_argument('number', nargs='?', type=int, help='Entry number')
    p.add_argument('--json', action='store_true', help='JSON output')

    # list
    p = sub.add_parser('list', aliases=['ls'], help='List entries across files')
    p.add_argument('directory', nargs='?', default='.', help='Directory')
    p.add_argument('--json', action='store_true', help='JSON output')

    # create
    p = sub.add_parser('create', help='Interactive entry creation')
    p.add_argument('file', help='Q3N file to append to')

    # edit
    p = sub.add_parser('edit', help='Edit an entry interactively')
    p.add_argument('file', help='Q3N file')
    p.add_argument('number', nargs='?', type=int, help='Entry number')

    # search
    p = sub.add_parser('search', help='Search entry text (regex)')
    p.add_argument('pattern', help='Regex pattern')
    p.add_argument('directory', nargs='?', default='.', help='File or directory')

    # stats
    p = sub.add_parser('stats', help='Show collection statistics')
    p.add_argument('directory', nargs='?', default='.', help='File or directory')
    p.add_argument('--json', action='store_true', help='JSON output')

    # export
    p = sub.add_parser('export', help='Export entries')
    p.add_argument('file', help='Source Q3N file')
    p.add_argument('-o', '--output', help='Output file')
    p.add_argument('-f', '--format', default='txt',
                   choices=['q3n', 'json', 'md', 'txt'],
                   help='Export format')

    # import
    p = sub.add_parser('import', help='Import entries')
    p.add_argument('source', help='Source file')
    p.add_argument('directory', help='Output file or directory')
    p.add_argument('-f', '--format', default='q3n',
                   choices=['q3n', 'json'], help='Source format')

    # index
    p = sub.add_parser('index', help='Generate index')
    p.add_argument('directory', nargs='?', default='.', help='File or directory')

    # init
    p = sub.add_parser('init', help='Create empty Q3N file')
    p.add_argument('file', help='File path')

    # validate
    p = sub.add_parser('validate', help='Validate URIs in a Q3N file')
    p.add_argument('file', help='Q3N file')

    # fortune
    p = sub.add_parser('fortune', help='Display random quote as fortune')
    p.add_argument('directory', nargs='?', default='.',
                   help='File or directory to source fortunes from')
    p.add_argument('-c', '--count', type=int, default=1,
                   help='Number of fortunes to show')
    p.add_argument('--art', choices=['cookie', 'penguin', 'book', 'lightbulb',
                                     'computer', 'star', 'cat', 'brain',
                                     'scroll'],
                   help='Specific ASCII art')
    p.add_argument('--no-art', action='store_true',
                   help='Suppress ASCII art')
    p.add_argument('--filter-tag', metavar='TAG',
                   help='Only show entries whose tag contains TAG')
    p.add_argument('--filter-scheme', metavar='SCHEME',
                   help='Only show entries with this URI scheme (e.g. isbn, doi, q3n)')

    # cite
    p = sub.add_parser('cite', help='Format entries as citations (MLA, APA, Chicago, BibTeX)')
    p.add_argument('file', nargs='?', help='Q3N file')
    p.add_argument('--style', default='apa',
                   choices=['mla', 'apa', 'chicago', 'bibtex'],
                   help='Citation style (default: apa)')
    p.add_argument('--entry', type=int, default=None, metavar='N',
                   help='1-based entry index (default: first)')
    p.add_argument('--all', action='store_true', dest='all_entries',
                   help='Print all entries')

    # run
    p = sub.add_parser('run', help='Run a plugin standalone')
    p.add_argument('plugin', help='Plugin name')
    p.add_argument('file', nargs='?', help='Q3N file to load')
    p.add_argument('plugin_args', nargs='*', metavar='arg', help='Arguments for the plugin')

    # tutorial
    p = sub.add_parser('tutorial',
                       help='Interactive tutorial for first-time users')

    # help
    p = sub.add_parser('help', help='Show man page or command help')
    p.add_argument('command_name', nargs='?', help='Command to get help for')

    args = parser.parse_args()

    if getattr(args, 'no_color', False):
        global USE_COLOR
        USE_COLOR = False

    cmds = {
        'show': cmd_show, 'list': cmd_list, 'ls': cmd_list,
        'create': cmd_create, 'edit': cmd_edit,
        'search': cmd_search, 'stats': cmd_stats,
        'export': cmd_export, 'import': cmd_import,
        'index': cmd_index, 'init': cmd_init,
        'validate': cmd_validate,
        'fortune': cmd_fortune,
        'cite': cmd_cite,
        'run': cmd_run,
        'tutorial': cmd_tutorial, 'help': cmd_help,
    }

    fn = cmds.get(args.command)
    if fn:
        return fn(args)
    parser.print_help()
    return 0


if __name__ == '__main__':
    sys.exit(main())
