#!/usr/bin/env python3
"""
q3n — CLI for Q3N (Quote Triple-Slash Notation) files.

Usage:
    q3n show <file> [n]       Display entries (with optional entry number)
    q3n list [dir]            List entries across files
    q3n create <file>         Interactive entry creation (wizard)
    q3n edit <file> [n]       Edit an entry interactively
    q3n search <pattern> [dir] Search entry text (regex)
    q3n stats [dir]           Show collection statistics
    q3n export <file> -o <path> -f <fmt>  Export (txt|json|md|q3n)
    q3n import <src> <dest>   Import entries from another file
    q3n index [dir]           Generate a markdown index
    q3n init <file>           Create a new empty Q3N file
"""
import sys
import os
import json
import re as re_module
from pathlib import Path
from datetime import datetime

