def cmd_help(args):
    """Show detailed help for a command, or the man page."""
    if args.command_name:
        # Show subcommand help via argparse
        import subprocess
        import shutil
        # If man is available and this is a general help, use man
        if shutil.which('man') and args.command_name in ('man', 'manual'):
            return _show_man()
        # Otherwise print brief help listing
        print(bold('Q3N commands:'))
        for cmd, desc in [
            ('show FILE [n]', 'Display entries'),
            ('list [DIR]', 'List entries across files'),
            ('create FILE', 'Interactive entry creation'),
            ('edit FILE [n]', 'Edit an entry'),
            ('search PATTERN [DIR]', 'Search entry text'),
            ('stats [DIR]', 'Show collection statistics'),
            ('export FILE -o OUT -f FMT', 'Export entries'),
            ('import SRC DEST', 'Import entries'),
            ('index [DIR]', 'Generate markdown index'),
            ('init FILE', 'Create empty Q3N file'),
            ('tutorial', 'Interactive tutorial'),
            ('help [CMD]', 'This help or man page'),
        ]:
            print(f'  {green(cmd):30} {dim(desc)}')
        print(f'\n  {dim("See q3n <command> --help for detailed options")}')
        return 0

    return _show_man()


def _show_man():
    """Display the man page."""
    man_path = Path(__file__).resolve().parent.parent / 'docs' / 'man' / 'q3n.1'
    if not man_path.exists():
        print(f'{yellow("Man page not found at")} {man_path}')
        return 1

    import subprocess
    import shutil
    if shutil.which('man'):
        try:
            subprocess.run(['man', str(man_path)], check=True)
            return 0
        except subprocess.CalledProcessError:
            pass

    # Fallback: strip roff and print
    text = man_path.read_text()
    for line in text.split('\n'):
        if line.startswith('.\\"') or line.startswith('.') and not line.startswith('.SH'):
            continue
        print(line)
    return 0


def cmd_validate(args):
    from core.q3n import validate_uri
    entries = parse_file(Path(args.file))
    any_errors = False
    for i, entry in enumerate(entries, 1):
        errs = validate_uri(entry.uri)
        short_uri = entry.uri[:60] + ('…' if len(entry.uri) > 60 else '')
        if errs:
            any_errors = True
            print(f'entry {i} ({short_uri}): {red(errs[0])}')
        else:
            print(f'entry {i} ({short_uri}): {green("OK")}')
    return 1 if any_errors else 0


def cmd_cite(args):
    _repo_root_path = Path(__file__).resolve().parent.parent
    if str(_repo_root_path) not in sys.path:
        sys.path.insert(0, str(_repo_root_path))
    try:
        from app.plugins.cite.formatter import format_citation
        from app.plugins.cite import _run_standalone
    except ImportError as e:
        print(red(f'Citation plugin unavailable: {e}'), file=sys.stderr)
        return 1
    entries = parse_file(Path(args.file)) if args.file else []
    plugin_args = ['--style', args.style]
    if args.all_entries:
        plugin_args.append('--all')
    if args.entry is not None:
        plugin_args += ['--entry', str(args.entry)]
    _run_standalone(entries, plugin_args)
    return 0


def cmd_run(args):
    _repo_root_path = Path(__file__).resolve().parent.parent
    if str(_repo_root_path) not in sys.path:
        sys.path.insert(0, str(_repo_root_path))
    try:
        from app.src.core.plugin_manager import PluginManager
    except ImportError:
        print(red('app/ directory not found — plugin system unavailable'), file=sys.stderr)
        return 1
    pm = PluginManager()
    pm.discover()
    entries = []
    if args.file:
        try:
            entries = parse_file(Path(args.file))
        except Exception as e:
            print(red(f'Could not read {args.file}: {e}'), file=sys.stderr)
            return 1
    try:
        pm.run_standalone(args.plugin, entries, args.plugin_args or [])
    except KeyError:
        print(red(f'Plugin not found: {args.plugin}'), file=sys.stderr)
        available = [n for n, _ in pm.list_plugins() if n in pm._standalones]
        if available:
            print(f'Available standalone plugins: {", ".join(available)}')
        return 1
    return 0


def cmd_init(args):
    path = Path(args.file)
    if path.exists():
        print(f'  {yellow(f"{path} already exists")}')
        confirm = input(f'  {cyan(SYM["arrow"])} Overwrite? (y/N): ').strip().lower()
        if confirm != 'y':
            return 1
    from core.q3n import serialize
    header = f'#!q3n-format\n# Created: {datetime.now().strftime("%Y-%m-%d")}\n'
    path.write_text(header + '\n', encoding='utf-8')
    print(f'  {green(SYM["check"])} {bold(str(path))} initialized')
    return 0


